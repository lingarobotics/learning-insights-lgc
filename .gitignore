# ================================
# Dependencies (ALL levels)
# ================================
node_modules/
**/node_modules/

# ================================
# Build outputs
# ================================
dist/
build/
out/
.next/
.vercel/
*.tsbuildinfo

# ================================
# Environment & secrets
# ================================
.env
.env.*
!.env.example

# ================================
# Logs & debugging
# ================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ================================
# OS junk
# ================================
.DS_Store
Thumbs.db
desktop.ini

# ================================
# Editors / IDE
# ================================
.vscode/
.idea/
*.swp
*.swo

# ================================
# Cache & temp
# ================================
.cache/
.temp/
.tmp/
.eslintcache

# ================================
# Testing / coverage
# ================================
coverage/

# ================================
# Vite / tooling temp
# ================================
vite.config.*.timestamp-*

# ================================
# Archives / packaged files
# ================================
*.tgz
*.zip

# ================================
# Misc unwanted
# ================================
*.local

# ================================
# Server-specific (future-safe)
# ================================
uploads/
*.sqlite
*.db

# ================================
# IMPORTANT: Track your content
# ================================
!insights/
!insights/**/*.md

# ================================
# Git safety (prevent mistakes)
# ================================
.gitmodules